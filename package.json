{
  "name": "forgeui-monorepo",
  "version": "0.2.0",
  "private": true,
  "description": "ForgeUI — Figma → React generation plus a design-token verify engine.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "forgeui": "packages/cli/bin/forgeui.mjs"
  },
  "scripts": {
    "build:packages": "tsc -b packages/core packages/generate packages/verify packages/cli",
    "build:web": "npm run build --workspace apps/web",
    "build": "npm run build:packages && npm run build:web",
    "pretest": "npm run build:packages",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b packages/core packages/generate packages/verify packages/cli",
    "clean": "tsc -b --clean packages/core packages/generate packages/verify packages/cli",
    "forgeui": "node packages/cli/bin/forgeui.mjs",
    "web": "npm run dev --workspace apps/web"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
